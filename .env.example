# ============================================================
# DocuFlow — Variables de Entorno
# Copia este archivo como .env y completa los valores.
#   Windows:  copy .env.example .env
#   Linux:    cp .env.example .env
# ============================================================

# --- Clave API de Groq (obligatoria) ---
# Regístrate en https://console.groq.com/keys
GROQ_API_KEY=gsk_TU_CLAVE_AQUI

# --- Modelo LLM ---
# Opciones: llama-3.3-70b-versatile | llama-3.1-8b-instant | gemma2-9b-it | mixtral-8x7b-32768
LLM_MODEL=llama-3.3-70b-versatile

# --- Qdrant (base de datos vectorial) ---
# Modo: "local" (disco, sin Docker) | "remote" (requiere Docker)
QDRANT_MODE=local
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- Colección vectorial ---
COLLECTION_NAME=docuflow_core

# --- Servidor Backend ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
